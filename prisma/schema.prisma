generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ───────────────────────── Auth (reused from cm-local) ─────────────────────────

model User {
  id                  Int       @id @default(autoincrement())
  firstName           String
  lastName            String
  email               String    @unique
  password            String
  image               String?
  role                Role      @default(MEMBER)
  province            String?
  amphoe              String?
  district            String?
  zone                String?
  emailVerified       DateTime?
  resetToken          String?   @unique
  resetTokenCreatedAt DateTime?
  resetTokenExpiresAt DateTime?
  lastPasswordReset   DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  surveys             Survey[]

  @@index([email])
  @@index([role])
}

enum Role {
  MEMBER
  ADMIN
  SUPERADMIN
}

// ───────────────────────── แบบสอบถามผลกระทบ สสส. ─────────────────────────
// กลุ่มเป้าหมาย: ประชาชนไทยอายุ 15 ปีขึ้นไป พักอาศัยต่อเนื่อง > 6 เดือน

enum CollectionSite {
  VILLAGE   // หมู่บ้าน
  WORKPLACE // สถานประกอบการ
  SCHOOL    // สถานศึกษา
}

model Survey {
  id              Int             @id @default(autoincrement())
  questionnaireNo String?         // เลขที่แบบสอบถาม

  // ผู้ตรวจสอบข้อมูล
  verifierName    String?
  verifierPhone   String?
  verifiedAt      DateTime?

  // ผู้เก็บข้อมูล
  collectorName   String?
  collectorPhone  String?
  collectedAt     DateTime?
  siteType        CollectionSite  @default(VILLAGE)

  // คัดกรองกลุ่มเป้าหมาย (1.6 พักอาศัย>6ด. / 1.7 ยินยอม / 1.11 อายุ≥15)
  eligible         Boolean  @default(true)  // ผ่านเกณฑ์หรือไม่
  ineligibleReason String?                  // เหตุที่ไม่เข้าเกณฑ์ (ถ้า eligible=false)

  // ── ส่วนที่ 1: ข้อมูลทั่วไป ──
  villageNo        String?  // 1.1 หมู่ที่
  villageName      String?  // 1.2
  province         String?  // 1.3
  amphoe           String?  // 1.4
  tambon           String?  // 1.5
  residence6Months Boolean? // 1.6 พักอาศัย > 6 เดือน
  consentGiven     Boolean  @default(false) // 1.7 ใบยินยอม
  consentAt        DateTime?
  nationalId       String?  // 1.8 (ไม่บังคับ)
  prefix           String?  // 1.9 คำนำหน้า
  firstName        String?  // 1.9
  lastName         String?  // 1.9
  phone            String?  // 1.9
  gender           String?  // 1.10
  genderOther      String?
  birthDate        String?  // 1.11 วัน/เดือน/ปีเกิด (พ.ศ.)
  religion         String?  // 1.12
  religionOther    String?
  rights           String?  @db.Text // 1.13 บัตร/สิทธิ (JSON string[])
  weightKg         Decimal? @db.Decimal(5, 2)  // 1.14
  heightCm         Decimal? @db.Decimal(5, 2)  // 1.15
  waistCm          Decimal? @db.Decimal(6, 2)  // 1.16 (หน่วย ซม., ทศนิยม)
  diseases         String?  @db.Text // 1.17 โรคที่ได้รับวินิจฉัย (JSON string[])
  diseaseOther     String?
  eduStatus        String?  // 1.18 สถานภาพการศึกษา
  eduLevel         String?  // 1.19 ระดับการศึกษาล่าสุด

  // ── ส่วนที่ 4: เมาแล้วขับ / บาดเจ็บจากอุบัติเหตุจราจร ──
  ddDroveAfterDrink String? // 4.1
  ddInjured         String? // 4.2

  // relations รายส่วน
  tobacco SurveyTobacco?
  alcohol SurveyAlcohol?

  creatorId Int?
  creator   User?    @relation(fields: [creatorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([province])
  @@index([amphoe])
  @@index([tambon])
  @@index([siteType])
  @@index([creatorId])
}

// ── ส่วนที่ 2: การสูบบุหรี่ ──
model SurveyTobacco {
  id          Int    @id @default(autoincrement())
  surveyId    Int    @unique
  survey      Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  homeSmoking String? // 2.1 การสูบในที่พักอาศัย
  smokeStatus String? // 2.2 สถานะการสูบ (1-6)

  // 2.3 เคยสูบประเภทใด (ตลอดช่วงชีวิต)
  everFactory   Boolean? // บุหรี่โรงงาน/ซิกาแรต
  everRolled    Boolean? // ยาเส้น/ขี้โย
  everEcig      Boolean? // บุหรี่ไฟฟ้า
  everSmokeless Boolean? // ยาสูบไม่มีควัน
  everOther     Boolean? // บารากู่/ไปป์/ซิการ์

  // 2.4 ปัจจุบันสูบประเภทใด + จำนวนต่อวัน
  curFactory      Boolean?
  curFactoryAmt   Int?    // มวนต่อวัน
  curRolled       Boolean?
  curRolledAmt    Int?    // มวนต่อวัน
  curEcig         Boolean?
  curEcigAmt      Int?    // ครั้งต่อวัน
  curSmokeless    Boolean?
  curSmokelessAmt Int?    // ครั้งต่อวัน
  curOther        Boolean?
  curOtherAmt     Int?    // ครั้ง/มวนต่อวัน

  firstCigTime String? // 2.5 มวนแรกหลังตื่นนอน
  quitAttempt  String? // 2.6 ความพยายามเลิก
}

// ── ส่วนที่ 3: การดื่มเครื่องดื่มแอลกอฮอล์ (AUDIT) ──
model SurveyAlcohol {
  id       Int    @id @default(autoincrement())
  surveyId Int    @unique
  survey   Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  q1Frequency Int? // 3.1 ความถี่การดื่ม (0-4)

  // 3.2 ชนิดที่ดื่ม + ปริมาณต่อวัน (เก็บคะแนน 0-4)
  beerDrink   Boolean?
  beerAmt     Int?
  liquorDrink Boolean?
  liquorAmt   Int?
  wineDrink   Boolean?
  wineAmt     Int?

  q3Binge      Int? // 3.3 ดื่มหนัก (ตามเพศ)
  q4CannotStop Int? // 3.4
  q5FailNormal Int? // 3.5
  q6Morning    Int? // 3.6
  q7Guilt      Int? // 3.7
  q8Blackout   Int? // 3.8
  q9Injury     Int? // 3.9 (0/2/4)
  q10Advised   Int? // 3.10 (0/2/4)

  auditScore Int?    // คะแนนรวม (คำนวณ)
  riskLevel  String? // ระดับความเสี่ยง (คำนวณ)
}
